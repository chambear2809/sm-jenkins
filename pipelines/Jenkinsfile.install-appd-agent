pipeline {
    agent { label 'linux' }

    parameters {
        string(name: 'AGENT_TYPE', defaultValue: 'machine', description: 'AppDynamics agent type shown by smartagentctl install --help, such as machine, db, java, or node')
        string(name: 'BATCH_SIZE', defaultValue: '25', description: 'Number of hosts to process in parallel per batch (1-256)')
        string(name: 'REMOTE_INSTALL_DIR', defaultValue: '/opt/appdynamics/appdsmartagent', description: 'Remote directory where Smart Agent is installed')
        string(name: 'SSH_PORT', defaultValue: '22', description: 'SSH port for remote hosts')
        string(name: 'APPD_USER', defaultValue: 'ubuntu', description: 'User to run agent process')
        string(name: 'APPD_GROUP', defaultValue: 'ubuntu', description: 'Group to run agent process')
        string(name: 'AGENT_VERSION', defaultValue: '', description: 'Agent version to install (optional)')
        choice(name: 'DOWNLOAD_PROTOCOL', choices: ['download_portal', 'local', 'http'], description: 'Download protocol for agent')
        string(name: 'DOWNLOAD_URI', defaultValue: '', description: 'Download URI (required if using local or http protocol)')
        booleanParam(name: 'USE_SA_INFO', defaultValue: false, description: 'Pass --use_sa_info to share Smart Agent controller settings')
        string(name: 'CONTROLLER_HOST_NAME', defaultValue: '', description: 'Controller host name for agent install (optional)')
        string(name: 'CONTROLLER_PORT', defaultValue: '', description: 'Controller port for agent install (optional)')
        booleanParam(name: 'ENABLE_SSL', defaultValue: false, description: 'Pass --enable_ssl to smartagentctl')
        string(name: 'CONTROLLER_ACCOUNT_NAME', defaultValue: '', description: 'Controller account name for agent install (optional)')
        string(name: 'CONTROLLER_ACCESS_KEY_CREDENTIAL_ID', defaultValue: 'account-access-key', description: 'Secret Text credential ID for controller access key (optional; used only when controller/account fields are set)')
        string(name: 'APPLICATION_NAME', defaultValue: '', description: 'Application name for machine/java/node agents (optional)')
        string(name: 'TIER_NAME', defaultValue: '', description: 'Tier name for machine/java/node agents (optional)')
        string(name: 'NODE_NAME', defaultValue: '', description: 'Node name for machine/java/node agents (optional)')
        string(name: 'AGENT_NAME', defaultValue: '', description: 'Agent name for db agent (optional)')
        text(name: 'ADDITIONAL_SMARTAGENTCTL_ARGS', defaultValue: '', description: 'Optional extra smartagentctl arguments, one argument per line. Use --flag=value or put --flag and its value on separate lines.')
        booleanParam(name: 'API_CHECK_ENABLED', defaultValue: true, description: 'Check Client Inventory API after pipeline host summary')
        string(name: 'API_BASE_URL', defaultValue: 'https://fso-tme.saas.appdynamics.com/fm-service/v1', description: 'Client Inventory API base URL')
        string(name: 'API_TOKEN_CREDENTIAL_ID', defaultValue: 'sf-api-token', description: 'Secret Text credential ID for the X-SF-Token API token')
    }

    environment {
        STAGING_DIR = "${WORKSPACE}/appd-agent-install"
        RESULTS_DIR = "${WORKSPACE}/appd-agent-install/results"
    }

    stages {
        stage('Preparation') {
            steps {
                script {
                    validateInstallParams()

                    withCredentials([string(credentialsId: 'deployment-hosts', variable: 'HOSTS_LIST')]) {
                        def hostsList = parseHosts(HOSTS_LIST)
                        env.TARGET_HOSTS = hostsList.join('\n')
                        echo "Preparing ${agentType()} agent installation on ${hostsList.size()} hosts in batches of ${batchSize()}: ${hostsList.join(', ')}"
                    }

                    sh """
                        rm -rf ${shellQuote(env.STAGING_DIR)}
                        mkdir -p ${shellQuote(env.RESULTS_DIR)}
                    """
                }
            }
        }

        stage('Verify Smart Agent') {
            steps {
                script {
                    withCredentials([
                        sshUserPrivateKey(credentialsId: 'ssh-private-key', keyFileVariable: 'SSH_KEY_FILE', usernameVariable: 'SSH_USERNAME')
                    ]) {
                        runBatches(targetHosts(), batchSize(), 'Verify Smart Agent') { host ->
                            withHostResult(host) {
                                verifySmartAgentPresent(host, env.SSH_USERNAME, env.SSH_KEY_FILE)
                            }
                        }
                    }
                }
            }
        }

        stage('Install AppDynamics Agent') {
            steps {
                script {
                    def needsControllerKey = controllerAccessKeyRequired()
                    def credentialBindings = [sshUserPrivateKey(credentialsId: 'ssh-private-key', keyFileVariable: 'SSH_KEY_FILE', usernameVariable: 'SSH_USERNAME')]
                    if (needsControllerKey) {
                        credentialBindings << string(credentialsId: params.CONTROLLER_ACCESS_KEY_CREDENTIAL_ID.trim(), variable: 'CONTROLLER_ACCESS_KEY')
                    }

                    withCredentials(credentialBindings) {
                        runBatches(targetHosts(), batchSize(), 'Install AppDynamics Agent') { host ->
                            withHostResult(host) {
                                installAgentOnHost(host, env.SSH_USERNAME, env.SSH_KEY_FILE, needsControllerKey)
                            }
                        }
                    }
                }
            }
        }

        stage('Verify Agent Installation') {
            steps {
                script {
                    withCredentials([
                        sshUserPrivateKey(credentialsId: 'ssh-private-key', keyFileVariable: 'SSH_KEY_FILE', usernameVariable: 'SSH_USERNAME')
                    ]) {
                        runBatches(targetHosts(), batchSize(), 'Verify AppDynamics Agent') { host ->
                            withHostResult(host) {
                                verifyAgentOnHost(host, env.SSH_USERNAME, env.SSH_KEY_FILE)
                            }
                        }
                    }
                }
            }
        }

        stage('Summary') {
            steps {
                script {
                    summarizeHostResults(targetHosts(), "${agentType()} agent installation")
                }
            }
        }

        stage('Check Client Inventory API') {
            when {
                expression { return params.API_CHECK_ENABLED }
            }
            steps {
                script {
                    runClientInventoryApiCheck()
                }
            }
        }
    }

    post {
        success {
            echo "${agentType()} agent successfully installed on all hosts"
        }
        failure {
            echo "${agentType()} agent installation failed. Check host result summary for details."
        }
        always {
            sh "rm -rf ${shellQuote(env.STAGING_DIR)}"
        }
    }
}

def verifySmartAgentPresent(String host, String sshUsername, String sshKeyFile) {
    def remoteDir = params.REMOTE_INSTALL_DIR.trim()
    def ssh = sshCommand(sshKeyFile, params.SSH_PORT.trim(), knownHostsFile(host), sshUsername, host)
    def type = agentType()
    def command = """
        test -f ${shellQuote("${remoteDir}/smartagentctl")} &&
        cd ${shellQuote(remoteDir)} &&
        if ! sudo ./smartagentctl install --help | sed -n '/Available Commands:/,/Flags:/p' | grep -Eq '^[[:space:]]+${type}[[:space:]]'; then
            echo ${shellQuote("smartagentctl install does not support agent type: ${type}")}
            sudo ./smartagentctl install --help | sed -n '/Available Commands:/,/Flags:/p'
            exit 1
        fi
        echo ${shellQuote("Smart Agent supports install ${type}")}
    """.stripIndent().trim()
    sh "${ssh} ${shellQuote(command)}"
}

def installAgentOnHost(String host, String sshUsername, String sshKeyFile, boolean includeControllerAccessKey) {
    def remoteDir = params.REMOTE_INSTALL_DIR.trim()
    def ssh = sshCommand(sshKeyFile, params.SSH_PORT.trim(), knownHostsFile(host), sshUsername, host)
    def args = ['sudo', './smartagentctl', 'install', agentType()]

    if (params.AGENT_VERSION?.trim()) {
        args += ['--agent_version', params.AGENT_VERSION.trim()]
    }

    if (params.DOWNLOAD_PROTOCOL == 'local') {
        args += ['--download_uri', params.DOWNLOAD_URI.trim(), '--download_protocol', 'local']
    } else if (params.DOWNLOAD_PROTOCOL == 'http') {
        args += ['--download_uri', params.DOWNLOAD_URI.trim(), '--download_protocol', 'http']
    }

    if (params.USE_SA_INFO) {
        args += ['--use_sa_info']
    }
    if (params.CONTROLLER_HOST_NAME?.trim()) {
        args += ['--controller_host_name', params.CONTROLLER_HOST_NAME.trim()]
    }
    if (params.CONTROLLER_PORT?.trim()) {
        args += ['--controller_port', params.CONTROLLER_PORT.trim()]
    }
    if (params.ENABLE_SSL) {
        args += ['--enable_ssl']
    }
    if (params.CONTROLLER_ACCOUNT_NAME?.trim()) {
        args += ['--controller_account_name', params.CONTROLLER_ACCOUNT_NAME.trim()]
    }
    if (includeControllerAccessKey) {
        args += ['--controller_account_access_key', env.CONTROLLER_ACCESS_KEY]
    }

    if (supportsApplicationFields(agentType())) {
        if (params.APPLICATION_NAME?.trim()) {
            args += ['--application_name', params.APPLICATION_NAME.trim()]
        }
        if (params.TIER_NAME?.trim()) {
            args += ['--tier_name', params.TIER_NAME.trim()]
        }
        if (params.NODE_NAME?.trim()) {
            args += ['--node_name', params.NODE_NAME.trim()]
        }
    }

    if (agentType() == 'db' && params.AGENT_NAME?.trim()) {
        args += ['--agent_name', params.AGENT_NAME.trim()]
    }

    args += ['--user', params.APPD_USER.trim(), '--group', params.APPD_GROUP.trim()]
    args += parseAdditionalSmartAgentArgs(params.ADDITIONAL_SMARTAGENTCTL_ARGS)

    def installCommand = args.collect { shellQuote(it) }.join(' ')
    runSmartAgentCommand(ssh, "cd ${shellQuote(remoteDir)} && ${installCommand}")
}

def verifyAgentOnHost(String host, String sshUsername, String sshKeyFile) {
    def remoteDir = params.REMOTE_INSTALL_DIR.trim()
    def ssh = sshCommand(sshKeyFile, params.SSH_PORT.trim(), knownHostsFile(host), sshUsername, host)
    runSmartAgentCommand(ssh, "cd ${shellQuote(remoteDir)} && sudo ./smartagentctl status")

    def service = serviceNameForAgentType(agentType())
    if (service) {
        def command = """
            sudo systemctl --no-pager --full status ${shellQuote(service)} | sed -n '1,20p'
            sudo systemctl is-active --quiet ${shellQuote(service)}
        """.stripIndent().trim()
        sh "${ssh} ${shellQuote(command)}"
    }
}

def runSmartAgentCommand(String ssh, String remoteCommand) {
    sh """
        set +x
        set +e
        output=\$(${ssh} ${shellQuote(remoteCommand)} 2>&1)
        status=\$?
        set -e
        printf '%s\\n' "\$output"
        if [ "\$status" -ne 0 ]; then
            exit "\$status"
        fi
        if printf '%s\\n' "\$output" | grep -Eq '"error"[[:space:]]*:[[:space:]]*true'; then
            echo 'smartagentctl reported error=true'
            exit 1
        fi
    """
}

def controllerAccessKeyRequired() {
    return params.CONTROLLER_ACCOUNT_NAME?.trim() || params.CONTROLLER_HOST_NAME?.trim() || params.CONTROLLER_PORT?.trim()
}

def supportsApplicationFields(String agentType) {
    return ['machine', 'java', 'node'].contains(agentType)
}

def serviceNameForAgentType(String agentType) {
    def services = [
        machine: 'appdynamics-machine-agent.service',
        db: 'appdynamics-db-agent.service'
    ]
    return services[agentType]
}

def parseAdditionalSmartAgentArgs(String rawValue) {
    if (!rawValue?.trim()) {
        return []
    }
    return rawValue.split('\n').collect { it.trim() }.findAll { it }.collect { value ->
        validateAdditionalSmartAgentArg(value)
        return value
    }
}

def validateInstallParams() {
    validateCommonParams()
    validateAgentType(agentType())
    validateLinuxName(params.APPD_USER, 'APPD_USER')
    validateLinuxName(params.APPD_GROUP, 'APPD_GROUP')
    validateOptionalSingleLine(params.AGENT_VERSION, 'AGENT_VERSION')
    validateDownloadSettings()
    validateOptionalHost(params.CONTROLLER_HOST_NAME, 'CONTROLLER_HOST_NAME')
    if (params.CONTROLLER_PORT?.trim()) {
        validatePort(params.CONTROLLER_PORT)
    }
    validateOptionalSingleLine(params.CONTROLLER_ACCOUNT_NAME, 'CONTROLLER_ACCOUNT_NAME')
    validateCredentialId(params.CONTROLLER_ACCESS_KEY_CREDENTIAL_ID, 'CONTROLLER_ACCESS_KEY_CREDENTIAL_ID')
    validateOptionalSingleLine(params.APPLICATION_NAME, 'APPLICATION_NAME')
    validateOptionalSingleLine(params.TIER_NAME, 'TIER_NAME')
    validateOptionalSingleLine(params.NODE_NAME, 'NODE_NAME')
    validateOptionalSingleLine(params.AGENT_NAME, 'AGENT_NAME')
    parseAdditionalSmartAgentArgs(params.ADDITIONAL_SMARTAGENTCTL_ARGS)
}

def validateCommonParams() {
    validateBatchSize(params.BATCH_SIZE)
    validatePort(params.SSH_PORT)
    validateSafeRemoteInstallDir(params.REMOTE_INSTALL_DIR)
}

def validateAgentType(String rawValue) {
    if (!(rawValue ==~ /^[A-Za-z][A-Za-z0-9_-]*$/)) {
        error("AGENT_TYPE must be a smartagentctl install subcommand token")
    }
}

def agentType() {
    return params.AGENT_TYPE.trim()
}

def validateDownloadSettings() {
    if (params.DOWNLOAD_PROTOCOL != 'download_portal') {
        validateSingleLine(params.DOWNLOAD_URI, 'DOWNLOAD_URI')
    }
    if (params.DOWNLOAD_PROTOCOL == 'http' && !(params.DOWNLOAD_URI.trim() ==~ /^https?:\/\/\S+$/)) {
        error('DOWNLOAD_URI must be an http:// or https:// URL when DOWNLOAD_PROTOCOL is http')
    }
}

def validateAdditionalSmartAgentArg(String value) {
    if (value.length() > 4096 || value.contains('\r') || value.contains('\u0000')) {
        error('ADDITIONAL_SMARTAGENTCTL_ARGS contains an invalid argument')
    }
}

def runClientInventoryApiCheck() {
    validateApiCheckParams()
    withCredentials([string(credentialsId: params.API_TOKEN_CREDENTIAL_ID.trim(), variable: 'SF_API_TOKEN')]) {
        sh """
            set +x
            API_BASE_URL=${shellQuote(params.API_BASE_URL.trim())} \
            OPENAPI_SPEC=${shellQuote("${env.WORKSPACE}/openapi.json")} \
            bash ${shellQuote("${env.WORKSPACE}/scripts/check-client-inventory-api.sh")}
        """
    }
}

def validateApiCheckParams() {
    validateApiBaseUrl(params.API_BASE_URL, 'API_BASE_URL')
    validateCredentialId(params.API_TOKEN_CREDENTIAL_ID, 'API_TOKEN_CREDENTIAL_ID')
    if (!fileExists("${env.WORKSPACE}/openapi.json")) {
        error('openapi.json not found in Jenkins workspace')
    }
    if (!fileExists("${env.WORKSPACE}/scripts/check-client-inventory-api.sh")) {
        error('scripts/check-client-inventory-api.sh not found in Jenkins workspace')
    }
}

def parseHosts(String hostsText) {
    def hosts = hostsText.replaceAll(',', '\n').split('\n').collect { it.trim() }.findAll { it && !it.startsWith('#') }.unique()
    if (hosts.isEmpty()) {
        error('No hosts provided in deployment-hosts credential')
    }
    hosts.each { validateHost(it) }
    return hosts
}

def targetHosts() {
    return env.TARGET_HOSTS.split('\n').collect { it.trim() }.findAll { it }
}

def runBatches(List hosts, int size, String actionName, Closure action) {
    def batches = hosts.collate(size)
    batches.eachWithIndex { batch, index ->
        echo "${actionName} batch ${index + 1}/${batches.size()} (${batch.size()} hosts)"
        def branches = [:]
        batch.each { batchHost ->
            def host = batchHost
            branches["${actionName} ${host}"] = {
                action(host)
            }
        }
        parallel branches
    }
}

def withHostResult(String host, Closure body) {
    try {
        body.call()
        markHostResult(host, 'SUCCESS', '')
    } catch (err) {
        def message = err.getMessage() ?: err.toString()
        markHostResult(host, 'FAILURE', message)
        echo "Host ${host} failed: ${message}"
    }
}

def markHostResult(String host, String status, String message) {
    def path = resultFile(host)
    if (status == 'SUCCESS' && fileExists(path) && readFile(path).startsWith('FAILURE')) {
        return
    }
    writeFile file: path, text: "${status}\n${message}\n"
}

def summarizeHostResults(List hosts, String operation) {
    def failed = []
    hosts.each { host ->
        def path = resultFile(host)
        if (!fileExists(path)) {
            failed << "${host} (no result recorded)"
        } else {
            def result = readFile(path)
            if (!result.startsWith('SUCCESS')) {
                failed << host
            }
        }
    }

    if (failed) {
        error("${operation} failed on ${failed.size()} host(s): ${failed.join(', ')}")
    }

    echo "${operation} succeeded on ${hosts.size()} host(s)"
}

def resultFile(String host) {
    return "${env.RESULTS_DIR}/${safeFileToken(host)}.result"
}

def sshCommand(String keyFile, String port, String knownHosts, String sshUsername, String host) {
    return "ssh -i ${shellQuote(keyFile)} -p ${shellQuote(port)} -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=${shellQuote(knownHosts)} -o BatchMode=yes -o ConnectTimeout=10 ${shellQuote("${sshUsername}@${host}")}"
}

def knownHostsFile(String host) {
    return "${env.STAGING_DIR}/known_hosts_${safeFileToken(host)}"
}

def shellQuote(Object value) {
    def text = value.toString()
    return "'" + text.replace("'", "'\"'\"'") + "'"
}

def safeFileToken(String value) {
    return value.replaceAll(/[^A-Za-z0-9_.-]/, '_')
}

def batchSize() {
    return params.BATCH_SIZE.trim().toInteger()
}

def validateBatchSize(String rawValue) {
    if (!(rawValue?.trim() ==~ /^[0-9]+$/)) {
        error('BATCH_SIZE must be a number')
    }
    def value = rawValue.trim().toInteger()
    if (value < 1 || value > 256) {
        error('BATCH_SIZE must be between 1 and 256')
    }
}

def validatePort(String rawValue) {
    if (!(rawValue?.trim() ==~ /^[0-9]+$/)) {
        error('Port values must be numeric')
    }
    def value = rawValue.trim().toInteger()
    if (value < 1 || value > 65535) {
        error('Port values must be between 1 and 65535')
    }
}

def validateHost(String host) {
    if (!(host ==~ /^[A-Za-z0-9][A-Za-z0-9._:-]*$/) || host.contains('..')) {
        error("Invalid host entry: ${host}")
    }
}

def validateOptionalHost(String rawValue, String name) {
    def value = rawValue?.trim()
    if (value && (!(value ==~ /^[A-Za-z0-9][A-Za-z0-9._-]*$/) || value.contains('..'))) {
        error("${name} must be a host name without scheme or path")
    }
}

def validateSafeRemoteInstallDir(String rawValue) {
    def value = rawValue?.trim()
    if (!value || value == '/' || value == '/opt' || value == '/opt/appdynamics') {
        error('REMOTE_INSTALL_DIR must be a specific directory under /opt/appdynamics/')
    }
    if (!(value ==~ /^\/opt\/appdynamics\/[A-Za-z0-9._\/-]+$/) || value.contains('..') || value.contains('//')) {
        error('REMOTE_INSTALL_DIR must stay under /opt/appdynamics/ and cannot contain whitespace, shell metacharacters, or traversal')
    }
}

def validateLinuxName(String rawValue, String name) {
    def value = rawValue?.trim()
    if (!(value ==~ /^[A-Za-z_][A-Za-z0-9_.-]*$/)) {
        error("${name} must be a valid Linux user/group name")
    }
}

def validateCredentialId(String rawValue, String name) {
    def value = rawValue?.trim()
    if (!(value ==~ /^[A-Za-z0-9_.:-]+$/)) {
        error("${name} must be a Jenkins credential ID without whitespace")
    }
}

def validateSingleLine(String rawValue, String name) {
    def value = rawValue?.trim()
    if (!value || value.contains('\n') || value.contains('\r')) {
        error("${name} must be a non-empty single-line value")
    }
}

def validateOptionalSingleLine(String rawValue, String name) {
    def value = rawValue?.trim()
    if (value && (value.contains('\n') || value.contains('\r'))) {
        error("${name} must be a single-line value")
    }
}

def validateApiBaseUrl(String rawValue, String name) {
    def value = rawValue?.trim()
    if (!value || value.contains(' ') || value.contains('\n') || value.contains('\r') || !(value.startsWith('https://') || value.startsWith('http://'))) {
        error("${name} must be an http:// or https:// URL without whitespace")
    }
}
